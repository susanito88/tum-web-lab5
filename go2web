#!/usr/bin/env python3
import subprocess
import sys
import os

# Get the directory where this script is located
script_dir = os.path.dirname(os.path.abspath(__file__))
go2web_py = os.path.join(script_dir, 'go2web.py')

# Run the Python script with all arguments
sys.exit(subprocess.call([sys.executable, go2web_py] + sys.argv[1:]))
